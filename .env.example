# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=changeme

# ── Google OAuth (shared by UserService + NotificationService) ────────────────
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── NotificationService (Google Calendar) ────────────────────────────────────
# Therapist's Google calendar email address
THERAPIST_EMAIL=therapist@gmail.com

# ── UserService (Gmail sender) ────────────────────────────────────────────────
GMAIL_FROM=noreply@yourdomain.com

# ── TherapistService ──────────────────────────────────────────────────────────
# Random secret used for field-level encryption (min 32 chars)
APP_ENCRYPTION_SECRET=

# ── Frontend URL (for CORS / email links in UserService) ─────────────────────
FRONTEND_URL=https://your-vercel-app.vercel.app
